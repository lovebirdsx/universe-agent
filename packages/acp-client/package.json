{
  "name": "@universe-agent/acp-client",
  "version": "1.0.2",
  "description": "CLI client for ACP servers",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lovebirdsx/universe-agent.git",
    "directory": "packages/acp-client"
  },
  "keywords": [
    "cli",
    "acp",
    "agent-client-protocol"
  ],
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "universe-agent-acp-client": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "start:dev": "cd ../../ && tsx apps/acp-client/src/index.ts",
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "lint:fix": "eslint --fix src",
    "clean": "tsc --build --clean",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "catalog:",
    "commander": "catalog:",
    "dotenv": "catalog:",
    "picocolors": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@universe-agent/config-eslint": "workspace:*",
    "@universe-agent/config-ts": "workspace:*",
    "eslint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
