{
  "name": "@universe-agent/cli",
  "version": "0.0.0",
  "description": "CLI for UniverseAgent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lovebirdsx/universe-agent.git",
    "directory": "packages/cli"
  },
  "keywords": ["cli", "ai", "agents", "universe-agent"],
  "type": "module",
  "files": ["dist"],
  "bin": {
    "universe-agent": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start:dev": "cd ../../ && tsx apps/cli/src/index.ts",
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:int": "vitest run --config vitest.int.config.ts",
    "test:watch": "vitest",
    "test:unit:watch": "vitest --config vitest.unit.config.ts",
    "test:int:watch": "vitest --config vitest.int.config.ts",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "lint:fix": "eslint --fix src",
    "clean": "tsc --build --clean",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@langchain/core": "catalog:",
    "@langchain/langgraph": "catalog:",
    "@langchain/openai": "catalog:",
    "@universe-agent/agent": "workspace:*",
    "commander": "catalog:",
    "dotenv": "catalog:",
    "jsonc-parser": "catalog:",
    "langchain": "catalog:",
    "picocolors": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@universe-agent/config-eslint": "workspace:*",
    "@universe-agent/config-ts": "workspace:*",
    "eslint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
