{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@universe-agent/config-ts/base",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false
  },
  "include": ["src"],
  "exclude": [
    "src/**/*.test-d.ts",
    "src/**/__tests__/**"
  ],
  "references": [{ "path": "../shared" }]
}
