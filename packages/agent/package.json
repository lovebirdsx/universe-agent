{
  "name": "@universe-agent/agent",
  "version": "0.0.0",
  "description": "LangGraph-based AI agent framework",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lovebirdsx/universe-agent.git",
    "directory": "packages/agent"
  },
  "keywords": ["ai", "agents", "langgraph", "langchain", "typescript"],
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --build",
    "lint": "eslint src",
    "lint:fix": "eslint --fix src",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:int": "vitest run --config vitest.int.config.ts",
    "test:watch": "vitest",
    "test:unit:watch": "vitest --config vitest.unit.config.ts",
    "test:int:watch": "vitest --config vitest.int.config.ts",
    "dev": "tsc --build --watch",
    "clean": "tsc --build --clean",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@langchain/anthropic": "catalog:",
    "@langchain/core": "catalog:",
    "@langchain/mcp-adapters": "catalog:",
    "@langchain/langgraph": "catalog:",
    "@langchain/langgraph-checkpoint": "catalog:",
    "@langchain/langgraph-sdk": "catalog:",
    "@langchain/openai": "catalog:",
    "@langfuse/langchain": "catalog:",
    "@langfuse/otel": "catalog:",
    "@opentelemetry/sdk-node": "catalog:",
    "fast-glob": "catalog:",
    "langchain": "catalog:",
    "langsmith": "catalog:",
    "micromatch": "catalog:",
    "yaml": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/micromatch": "catalog:",
    "@types/node": "catalog:",
    "@universe-agent/config-eslint": "workspace:*",
    "@universe-agent/config-ts": "workspace:*",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
