{
  "name": "@universe-agent/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --build",
    "lint": "eslint src",
    "lint:fix": "eslint --fix src",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:int": "vitest run --config vitest.int.config.ts",
    "test:watch": "vitest",
    "test:unit:watch": "vitest --config vitest.unit.config.ts",
    "test:int:watch": "vitest --config vitest.int.config.ts",
    "dev": "tsc --build --watch",
    "clean": "tsc --build --clean"
  },
  "devDependencies": {
    "@universe-agent/config-ts": "workspace:*",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
