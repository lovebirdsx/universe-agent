    "lint": "eslint src",
    "lint:fix": "eslint --fix src",
    "clean": "tsc --build --clean"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "catalog:",
    "commander": "catalog:",
    "dotenv": "catalog:",
    "picocolors": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@universe-agent/config-eslint": "workspace:*",
    "@universe-agent/config-ts": "workspace:*",
    "eslint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
