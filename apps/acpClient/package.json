{
  "name": "@universe-agent/acp-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "universe-agent-acp-client": "./dist/index.js"
  },
  "scripts": {
    "start:dev": "cd ../../ && tsx apps/acp-client/src/index.ts",
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
